[Unit]
Description=FiveM Whitelist API (FastAPI)
After=network.target mariadb.service

[Service]
Type=simple
User={{ fivem_user }}
Group={{ fivem_user }}
WorkingDirectory=/opt/whitelist-api
EnvironmentFile=/opt/whitelist-api/.env

ExecStart=/opt/whitelist-api/venv/bin/uvicorn main:app \
  --host 0.0.0.0 \
  --port {{ whitelist_api_port }} \
  --workers 2

Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=whitelist-api

NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
